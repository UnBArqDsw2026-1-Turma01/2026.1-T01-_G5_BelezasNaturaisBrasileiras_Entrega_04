// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id         String      @id
  email      String      @unique
  nome       String
  role       String      @default("COMMON_USER")
  fotoPerfil String?
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  trilhas    Trilha[]
  inscricoes Inscricao[]
  badges     Badge[]

  @@map("users")
}

model Ponto {
  id        String   @id @default(uuid())
  titulo    String
  descricao String?
  criadoPor String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("pontos")
}

// New models for chat, adapters and mediator
model ChatSession {
  id           String   @id @default(uuid())
  userAId      String
  userBId      String
  connectionId String?
  startedAt    DateTime @default(now())
  endedAt      DateTime?

  @@map("chat_sessions")
}

model ChatActivity {
  id            String   @id @default(uuid())
  chatSessionId String
  payload       Json
  createdAt     DateTime @default(now())

  @@map("chat_activity")
}

model ExternalProvider {
  id        String   @id @default(uuid())
  key       String   @unique
  provider  String
  config    Json
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  @@map("external_providers")
}

model NotificationLog {
  id         String   @id @default(uuid())
  to         String
  provider   String
  status     String
  externalId String?
  payload    Json?
  createdAt  DateTime @default(now())

  @@map("notification_logs")
}

model TrailLifecycleEvent {
  id          String   @id @default(uuid())
  trailId     String
  eventType   String
  payload     Json?
  status      String   @default("pending")
  createdAt   DateTime @default(now())
  processedAt DateTime?

  @@map("trail_lifecycle_events")
}

model TrailSagaState {
  id        String   @id @default(uuid())
  state     Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("trail_saga_states")
}

model Trilha {
  id            String      @id @default(uuid())
  titulo        String
  descricao     String
  organizadorId String
  pontoEncontro String
  dataInicio    DateTime
  vagasMaximas  Int
  status        String      @default("ATIVA")
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  organizador   User        @relation(fields: [organizadorId], references: [id])
  inscricoes    Inscricao[]
  badges        Badge[]

  @@map("trilhas")
}

model Inscricao {
  id                 String    @id @default(uuid())
  trilhaId           String
  usuarioId          String
  status             String    @default("PENDENTE")
  codigoConfirmacao  String?   @unique
  solicitadoEm       DateTime  @default(now())
  aceitoEm           DateTime?
  checkinEm          DateTime?

  trilha             Trilha    @relation(fields: [trilhaId], references: [id])
  usuario            User      @relation(fields: [usuarioId], references: [id])

  @@unique([trilhaId, usuarioId])
  @@map("inscricoes")
}

model Badge {
  id             String   @id @default(uuid())
  participanteId String
  trilhaId       String
  conquistadoEm  DateTime @default(now())

  participante   User   @relation(fields: [participanteId], references: [id])
  trilha         Trilha @relation(fields: [trilhaId], references: [id])

  @@unique([participanteId, trilhaId])
  @@map("badges")
}
