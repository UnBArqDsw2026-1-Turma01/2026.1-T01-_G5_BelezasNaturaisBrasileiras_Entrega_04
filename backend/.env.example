# Copie este arquivo para .env.local e ajuste os valores
# cp .env.example .env.local

# PostgreSQL
POSTGRES_USER=bnb_user
POSTGRES_PASSWORD=bnb_password
POSTGRES_DB=bnb_db

# pgAdmin (interface web: http://localhost:5050)
PGADMIN_DEFAULT_EMAIL=admin@bnb.dev
PGADMIN_DEFAULT_PASSWORD=admin

# Prisma
DATABASE_URL=postgresql://bnb_user:bnb_password@localhost:5432/bnb_db?schema=public

# Supabase Configuration
SUPABASE_URL=your_supabase_url
SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_KEY=your_service_key
