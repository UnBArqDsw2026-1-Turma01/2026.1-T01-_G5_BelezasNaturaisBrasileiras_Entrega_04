              { "key": "Authorization", "value": "Bearer {{TOKEN_ORG}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"titulo\": \"Chapada dos Veadeiros\",\n  \"descricao\": \"Trilha pelo cerrado goiano\",\n  \"pontoEncontro\": \"Portaria do Parque Nacional\",\n  \"dataInicio\": \"2026-07-15T08:00:00Z\",\n  \"vagasMaximas\": 20\n}"
